{
  "name": "kauk-raffle-2026",
  "version": "1.0.0",
  "private": true,
  "description": "KAUK Unity Coin Raffle 2026 — Karaitivu Association UK",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create kauk_raffle",
